{
  "name": "audiosandbox",
  "version": "0.0.0",
  "private": true,
  "description": "Browser-first audio editor + procedural sound-design toolkit for indie game developers.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter app dev",
    "build": "pnpm --filter @audiosandbox/engine build && pnpm --filter app build",
    "test": "pnpm --filter @audiosandbox/engine test",
    "build:engine": "pnpm --filter @audiosandbox/engine build",
    "build:app": "pnpm --filter app build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.1"
}
